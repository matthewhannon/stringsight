{
  "name": "stringsight",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first guitar pitch and chord monitoring in the browser.",
  "license": "MIT",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0 <12"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "benchmark:monophonic": "tsx scripts/evaluation.ts benchmark-monophonic",
    "corpus:generate": "tsx scripts/evaluation.ts generate",
    "corpus:validate": "tsx scripts/evaluation.ts validate",
    "dependencies:check": "node scripts/check-third-party-notices.mjs",
    "evaluate": "tsx scripts/evaluation.ts evaluate",
    "evaluate:monophonic": "tsx scripts/evaluation.ts monophonic-baseline",
    "evaluate:polyphonic-browser": "playwright test tests/e2e/polyphonic-evaluation.spec.ts --reporter=list",
    "evaluate:private-chords": "tsx scripts/evaluation.ts private-polyphonic",
    "evaluate:private-guitar": "tsx scripts/evaluation.ts private-monophonic",
    "evaluate:self-test": "tsx scripts/evaluation.ts self-test",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run dependencies:check && npm run corpus:validate && npm run evaluate:self-test && npm run evaluate:monophonic && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@tensorflow/tfjs-backend-cpu": "4.22.0",
    "@tensorflow/tfjs-backend-wasm": "4.22.0",
    "@tensorflow/tfjs-converter": "4.22.0",
    "@tensorflow/tfjs-core": "4.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
