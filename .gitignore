/IDMT-SMT-CHORDS.zip
/GuitarSet*.zip
/Guitar-TECHS*.zip
/annotation.zip
/audio_mono-mic.zip
/audio_mono-pickup_mix.zip
/audio_hex-pickup_debleeded.zip
/audio_hex-pickup_original.zip

